PAYLOAD_TEST_USER_EMAIL=user@btnopen.test
PAYLOAD_TEST_USER_PASSWORD=local
PAYLOAD_MCP_E2E_API_KEY=

# Namespaces every uploaded file in the Vercel Blob store under this path
# (e.g. `pr-42`). Leave empty in production and local development; preview
# deployments set it to isolate their media and delete the whole prefix on
# teardown. Only takes effect when BLOB_PAYLOAD_READ_WRITE_TOKEN is set.
BLOB_PAYLOAD_PREFIX=

# Clerk brokers GitHub sign-in for blog comments. Leave empty to run without
# comment auth (the composer degrades to a disabled state, and the Clerk-gated
# comment E2E tests skip). In Vercel, scope the development-instance keys to
# Preview and the production-instance keys to Production. The E2E suite requires
# development-instance keys (a production secret key is rejected by clerkSetup).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# The +clerk_test reader account the Clerk-authenticated comment E2E tests sign
# in as. Must exist in the Clerk development instance. Only used when the Clerk
# keys above are set; otherwise those tests skip.
CLERK_TEST_READER_EMAIL=e2e+clerk_test@btnopen.test
